@using Rent_A_Car.BL.DTOs.Vehicle
@model VehicleCreateDto
<section role="main" class="content-body">
	<header class="page-header">
		<h2>Dashboard</h2>

		<div class="right-wrapper text-end">
			<ol class="breadcrumbs">
				<li>
					<a>
						<i class="bx bx-home-alt"></i>
					</a>
				</li>

				<li><span>Dashboard</span></li>
				<li><span>Vehicle Category</span></li>
				<li><span>Create</span></li>


			</ol>

			<a style="cursor: auto;" class="sidebar-right-toggle"></a>
		</div>
	</header>
	<div class="row">
		<div class="col-lg-6">
			<a asp-action="Index" asp-controller="Category" class="btn btn-primary btn-icon-split">
				<span class="icon text-white-50">
					<i class="fa-solid fa-flag"></i>
				</span>
				<span class="text">Return List</span>
			</a>
			<br />
			<br />
			<section class="card" style="width:1140px">
                <form method="post">
                    <div class="form-group row">
                        <div class="col-sm-6 mb-3 mb-sm-0">
                            <label asp-for="Marka"></label>
                            <input type="text" class="form-control form-control-user" asp-for="Marka" />
                            <span asp-validation-for="Marka" class="text-danger"></span>
                        </div>
                        <div class="col-sm-6 mb-3 mb-sm-0">
                            <label asp-for="Model"></label>
                            <input type="text" class="form-control form-control-user" asp-for="Model" />
                            <span asp-validation-for="Model" class="text-danger"></span>
                        </div>
                        <div class="col-sm-6 mb-3 mb-sm-0">
                            <label asp-for="Year"></label>
                            <input type="number" class="form-control form-control-user" asp-for="Year" />
                            <span asp-validation-for="Year" class="text-danger"></span>
                        </div>
                        <div class="col-sm-6 mb-3 mb-sm-0">
                            <label asp-for="CategoryId"></label>
                            <select asp-for="CategoryId" asp-items="ViewBag.Category" class="form-control form-control-user">
                                <option value="">Select Category</option>
                            </select>
                            <span asp-validation-for="CategoryId" class="text-danger"></span>
                        </div>
                        <div class="col-sm-6 mb-3 mb-sm-0">
                            <label asp-for="ColorId"></label>
                            <select asp-for="ColorId" class="form-control form-control-user">
                                <option value="">Select Color</option>
                                <option value="0" style="color: red;">Red</option>
                                <option value="1" style="color: blue;">Blue</option>
                                <option value="2" style="color: black;">Black</option>
                                <option value="3" style="color: white; background-color: black;">White</option>
                                <option value="4" style="color: silver;">Silver</option>
                                <option value="5" style="color: gray;">Gray</option>
                                <option value="6" style="color: green;">Green</option>
                                <option value="7" style="color: yellow;">Yellow</option>
                                <option value="8" style="color: orange;">Orange</option>
                            </select>
                            <span asp-validation-for="ColorId" class="text-danger"></span>
                        </div>
                        <!-- Fuel Type Select -->
                        <div class="col-sm-6 mb-3 mb-sm-0">
                            <label asp-for="FuelType"></label>
                            <select asp-for="FuelType" class="form-control form-control-user">
                                <option value="">Select Fuel Type</option>
                                <option value="Gasoline">Petrol</option>
                                <option value="Diesel">Diesel</option>
                                <option value="Electric">Electric</option>
                                <option value="Hybrid">Hybrid</option>
                            </select>
                            <span asp-validation-for="FuelType" class="text-danger"></span>
                        </div>
                    </div>

                    <div asp-validation-summary="ModelOnly"></div>

                    <button type="submit" class="mb-1 mt-1 me-1 btn btn-primary">
                        <span class="icon text-white-50">
                            <i class="fa-solid fa-check"></i>
                        </span>
                        <span class="text">Submit</span>
                    </button>
                </form>


		</div>
	</div>
</section>
